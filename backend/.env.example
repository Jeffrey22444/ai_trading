# AI Provider API Configuration (统一使用 OPENAI_API_KEY)
# 默认使用 DeepSeek，如需更换请修改 config/agent.yaml
OPENAI_API_KEY=your_deepseek_api_key_here

# Binance Demo Trading API Configuration
# Create credentials at https://demo.binance.com/en/my/settings/api-management
# Do not use production Binance credentials while allow_live_trading is false.
BINANCE_API_KEY=your_binance_demo_api_key_here
BINANCE_API_SECRET=your_binance_demo_api_secret_here

# Database Configuration (SQLite)
# DATABASE_URL=sqlite:///./alphatransformer.db  # This is the default
