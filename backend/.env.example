# AI Provider API Configuration (统一使用 OPENAI_API_KEY)
# 默认使用 DeepSeek，如需更换请修改 config/agent.yaml
OPENAI_API_KEY=your_deepseek_api_key_here

# Hyperliquid testnet wallet credentials
# Use a dedicated testnet wallet. Never reuse a funded mainnet private key.
HYPERLIQUID_WALLET_ADDRESS=your_hyperliquid_testnet_wallet_address_here
HYPERLIQUID_PRIVATE_KEY=your_hyperliquid_testnet_private_key_here

# Database Configuration (SQLite)
# DATABASE_URL=sqlite:///./alphatransformer.db  # This is the default
